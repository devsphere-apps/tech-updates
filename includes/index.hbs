<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <title>Tech-updates — Feed</title>
    <link rel="shortcut icon" type="image/x-icon" href="favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="{{siteTitle}}" href="{{feedHref}}" />
    <script>
(function(){try{var t=localStorage.getItem("tech-updates-theme");if(t==="dark"||t==="light")document.documentElement.setAttribute("data-theme",t);else if(window.matchMedia&&window.matchMedia("(prefers-color-scheme: dark)").matches)document.documentElement.setAttribute("data-theme","dark");}catch(e){}})();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;1,9..144,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../assets/design-system.css" />
  </head>
  <body class="ds-body">
    <a class="ds-skip" href="#main-feed">Skip to feed</a>

    <header class="ds-header">
      <div class="ds-header__inner">
        <a href="../" class="ds-link ds-brand">Tech-updates</a>
        <div class="ds-header__actions">
          <button
            type="button"
            class="ds-btn ds-btn--ghost"
            data-theme-toggle
            aria-label="Toggle light or dark theme"
            title="Theme"
          >
            ◐
          </button>
          <a href="../" class="ds-btn ds-btn--primary">Back to Home</a>
        </div>
      </div>
    </header>

    <main id="main-feed" class="ds-container ds-feed-main">
      <div class="ds-feed-hero">
        <h1 class="ds-h2">Your feed</h1>
        <p class="ds-text" style="margin-top: 0.5rem; max-width: 36rem">
          Curated stories — open any card in a new tab.
        </p>
      </div>

      {{#each dates}}
      <section class="ds-feed-day">
        <h2 class="ds-day-label">
          <time class="js-relative-time" datetime="{{isoUtcPublishTime}}">{{isoOffsetPublishDate}}</time>
        </h2>
        {{#each sources}}
          {{#each articles}}
          <a
            class="ds-link ds-card ds-card--interactive ds-feed-card"
            href="{{link}}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="ds-feed-card__inner">
              {{#if imageUrl}}
              <div class="ds-feed-card__thumb">
                <img src="{{imageUrl}}" alt="" loading="lazy" decoding="async" />
              </div>
              {{/if}}
              <div class="ds-feed-card__body">
                <h3 class="ds-feed-card__title">{{title}}</h3>
                <div class="ds-feed-card__meta">
                  <span>{{../title}}</span>
                  <span class="ds-feed-card__dot" aria-hidden="true"></span>
                  <time class="js-relative-time" datetime="{{../../isoUtcPublishTime}}"></time>
                </div>
                <p class="ds-feed-card__excerpt">{{description}}</p>
              </div>
            </div>
          </a>
          {{/each}}
        {{/each}}
      </section>
      {{/each}}
    </main>

    <footer class="ds-footer ds-site-footer--feed">
      {{#if githubRunUrl}}
      <a href="{{githubRunUrl}}"><time datetime="{{siteBuildTimestamp}}">{{siteBuildTimestamp}}</time></a>
      {{else}}
      <time datetime="{{siteBuildTimestamp}}">{{siteBuildTimestamp}}</time>
      {{/if}}
      &nbsp;·&nbsp;
      <a href="{{projectUrl}}" target="_blank" rel="noopener">osmosfeed {{cliVersion}}</a>
    </footer>

    <script src="../assets/site.js" defer></script>
  </body>
</html>
